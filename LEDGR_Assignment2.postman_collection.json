{
  "info": {
    "name": "LEDGR — Assignment 2 (Part 4 Demonstration)",
    "description": "Covers: success, validation error, auth failure, auth success, and persistence proof for POST/GET /api/v1/transactions. Switch the base_url variable between local and the deployed Render URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "category_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Vijay\",\n  \"last_name\": \"Puttarevaiah\",\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"LedgerPass2026!\"\n}"
        }
      }
    },
    {
      "name": "2. Login (success)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('access_token', body.access_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"LedgerPass2026!\"\n}"
        }
      }
    },
    {
      "name": "3. Login (failure — wrong password)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"WrongPassword123!\"\n}"
        }
      }
    },
    {
      "name": "4. List categories (to grab a category_id)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  const groceries = body.find(c => c.name === 'Groceries');",
              "  if (groceries) pm.collectionVariables.set('category_id', groceries.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": "{{base_url}}/api/v1/categories"
      }
    },
    {
      "name": "5. Create transaction (success — 201)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{base_url}}/api/v1/transactions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 84.20,\n  \"type\": \"expense\",\n  \"date\": \"2026-06-29\",\n  \"category_id\": \"{{category_id}}\",\n  \"vendor\": \"Atlantic Superstore\",\n  \"payment_method\": \"visa_2491\",\n  \"note\": \"Weekly grocery run\"\n}"
        }
      }
    },
    {
      "name": "6. Create transaction (validation error — 422, negative amount)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": "{{base_url}}/api/v1/transactions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": -5,\n  \"type\": \"expense\",\n  \"date\": \"2026-06-29\",\n  \"category_id\": \"{{category_id}}\"\n}"
        }
      }
    },
    {
      "name": "7. Create transaction (auth failure — 401, no token)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/v1/transactions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 10,\n  \"type\": \"expense\",\n  \"date\": \"2026-06-29\",\n  \"category_id\": \"{{category_id}}\"\n}"
        }
      }
    },
    {
      "name": "8. List transactions (success — proof of persistence)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": "{{base_url}}/api/v1/transactions"
      }
    },
    {
      "name": "9. List transactions (filtered — category_id + min_amount)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": {
          "raw": "{{base_url}}/api/v1/transactions?category_id={{category_id}}&min_amount=50",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "transactions"],
          "query": [
            { "key": "category_id", "value": "{{category_id}}" },
            { "key": "min_amount", "value": "50" }
          ]
        }
      }
    },
    {
      "name": "10. List transactions (auth failure — 401, no token)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/transactions"
      }
    }
  ]
}
