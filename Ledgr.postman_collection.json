{
  "info": {
    "name": "LEDGR API",
    "description": "Collection for testing the LEDGR backend: auth, categories, and transactions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "transaction_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Vijay\",\n  \"last_name\": \"Puttarevaiah\",\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"LedgerPass2026!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Register - Duplicate Email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Vijay\",\n  \"last_name\": \"Puttarevaiah\",\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"LedgerPass2026!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"LedgerPass2026!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Invalid Credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vijay.p@dal.ca\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.collectionVariables.set('category_id', json[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        },
        {
          "name": "List Categories - No Token (401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('transaction_id', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 84.20,\n  \"type\": \"expense\",\n  \"date\": \"2026-06-29\",\n  \"category_id\": \"{{category_id}}\",\n  \"vendor\": \"Atlantic Superstore\",\n  \"payment_method\": \"debit\",\n  \"note\": \"Weekly groceries\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"]
            }
          }
        },
        {
          "name": "Create Transaction - Invalid Category (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10.00,\n  \"type\": \"expense\",\n  \"date\": \"2026-06-29\",\n  \"category_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"vendor\": \"Test Vendor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"]
            }
          }
        },
        {
          "name": "Create Transaction - Validation Error (422, future date)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10.00,\n  \"type\": \"expense\",\n  \"date\": \"2099-01-01\",\n  \"category_id\": \"{{category_id}}\",\n  \"vendor\": \"Test Vendor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"]
            }
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"]
            }
          }
        },
        {
          "name": "List Transactions - Filtered",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/transactions?date_from=2026-01-01&date_to=2026-12-31&vendor=Superstore&min_amount=10&max_amount=200&page=1&page_size=25",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"],
              "query": [
                { "key": "date_from", "value": "2026-01-01" },
                { "key": "date_to", "value": "2026-12-31" },
                { "key": "vendor", "value": "Superstore" },
                { "key": "min_amount", "value": "10" },
                { "key": "max_amount", "value": "200" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "List Transactions - No Token (401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "transactions"]
            }
          }
        }
      ]
    }
  ]
}
